# ============================================
# Environment Variables para o TENPortal
# ============================================
# Copie para .env e preencha os valores
# ============================================

# PostgreSQL
POSTGRES_PASSWORD=SUA_SENHA_FORTE_AQUI

# PgAdmin (acesso via pgadmin.alvarobiano.com.br)
PGADMIN_PASSWORD=SUA_SENHA_PGADMIN_AQUI

# MinIO Object Storage (bucket para arquivos)
MINIO_USER=tenportal
MINIO_PASSWORD=SUA_SENHA_MINIO_AQUI

# JWT (gere com: openssl rand -base64 32)
JWT_SECRET=SUA_CHAVE_JWT_AQUI_MINIMO_32_CARACTERES

# ============================================
# APLICAÇÕES (preenchido automaticamente)
# ============================================
NEXT_PUBLIC_API_URL=https://api.alvarobiano.com.br
DATABASE_URL=postgresql://tenportal:${POSTGRES_PASSWORD}@127.0.0.1:5432/tenportal
